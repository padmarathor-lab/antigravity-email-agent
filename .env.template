# Google OAuth Credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_refresh_token_here

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# Google Drive Folder ID containing knowledge base documents (PDF/DOCX)
KNOWLEDGE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# Digest Recipient Email (defaults to account owner if empty)
DIGEST_RECIPIENT_EMAIL=your_email@example.com

# Optional Configuration Overrides
# AGENT_PROCESSED_LABEL=Agent-Processed
# NEEDS_HUMAN_LABEL=Needs-Human
# GROQ_TRIAGE_MODEL=llama3-8b-8192
